<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TuDorsalShop" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores base -->
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_green</item>
        
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_dark</item>
        
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Estilos de componentes -->
        <item name="materialButtonStyle">@style/Widget.TuDorsal.Button</item>
        <item name="textInputStyle">@style/Widget.TuDorsal.TextInputLayout</item>
    </style>

    <style name="Widget.TuDorsal.Button" parent="Widget.MaterialComponents.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.TuDorsal.Rounded12</item>
        <item name="backgroundTint">@color/accent_green</item>

    </style>

    <style name="Widget.TuDorsal.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_green</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="ShapeAppearance.TuDorsal.Rounded12" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.TuDorsal.CardTop" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
    </style>
</resources>
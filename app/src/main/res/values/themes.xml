<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TuDorsalShop" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Colors -->
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_bone</item>
        
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="colorSurface">@color/surface_slate</item>
        <item name="colorOnSurface">@color/text_bone</item>
        
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.TuDorsal.Button</item>
        <item name="textInputStyle">@style/Widget.TuDorsal.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.TuDorsal.BottomNavigationView</item>
    </style>

    <!-- Rounded Buttons (12dp) -->
    <style name="Widget.TuDorsal.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.TuDorsal.Rounded12</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/accent_green</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- TextInputLayout with Surface background and Green stroke -->
    <style name="Widget.TuDorsal.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_green</item>
        <item name="boxBackgroundColor">@color/surface_slate</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/accent_green</item>
        <item name="android:textColorHint">@color/ui_text_dimmed</item>
        <item name="itemIconTint">@color/accent_green</item>
    </style>

    <!-- Bottom Navigation Customization -->
    <style name="Widget.TuDorsal.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface_slate</item>
        <item name="itemIconTint">@color/accent_green</item>
        <item name="itemTextColor">@color/text_bone</item>
    </style>

    <style name="ShapeAppearance.TuDorsal.Rounded12" parent="">
        <item name="cornerSize">12dp</item>
    </style>
</resources>